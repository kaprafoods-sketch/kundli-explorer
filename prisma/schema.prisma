generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url / directUrl are supplied by prisma.config.ts (Prisma 7)
}

model Chart {
  id         String   @id @default(cuid())
  name       String
  dob        String
  lat        Float
  lon        Float
  tz         String
  ayanamsha  String   @default("LAHIRI")
  data       Json
  createdAt  DateTime @default(now())
  ownerToken String?
  relation   String?

  // ── Engagement engine ──────────────────────────────────────────
  interests  String[] @default([]) // life-area ids the user cares about
  depth      String   @default("deep") // "quick" | "deep" — answer calibration
  intentNote String?  // optional free-text "anything on your mind?"

  messages TutorMessage[]

  @@index([ownerToken])
}

model TutorMessage {
  id        String   @id @default(cuid())
  chartId   String
  role      String
  content   String
  createdAt DateTime @default(now())

  // ── Per-message feedback (analytics / KB-gap / dataset only) ─────
  rating       String? // "true" | "not_quite"
  ratingReason String? // "too_generic" | "doesnt_match" | "too_vague"
  useful       Boolean?

  chart Chart @relation(fields: [chartId], references: [id], onDelete: Cascade)

  @@index([chartId])
}

