# Supabase Postgres — pooled (runtime) + direct (migrations)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:[YOUR_DB_PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[YOUR_DB_PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Anthropic — leave blank to use tutor in "key-later" mode
ANTHROPIC_API_KEY=
