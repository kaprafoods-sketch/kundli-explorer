  "interpretation_model": {
    "description": "The Planet + House + Sign formula the tutor teaches and the engine composes. Never store pre-written sentences for all 9×12×12 = 1296 combinations — compose them at runtime from the three pillars + dignity + aspects.",
    "composition": [
      "1. PLANET = what (karaka_of, keywords). 'Saturn brings discipline, delay and structure.'",
      "2. HOUSE = where / which life area (bhava.signifies). 'In the 10th house — career, status, authority.'",
      "3. SIGN = how / the flavor (rashi.keywords + ruler). 'In Capricorn — ambitious and structured.'",
      "4. DIGNITY = strength dial (dignity_rules). Modifies whether the expression is refined or strained.",
      "5. ASPECTS / CONJUNCTIONS = who else is influencing (aspect_rules). Layer last.",
      "6. Optionally weight by house class (kendra/trikona strengthen; dusthana stresses)."
    ],
    "example": {
      "input": {
        "planet": "saturn",
        "house": 10,
        "sign": "capricorn"
      },
      "derivation": "Saturn (discipline/karma) in the 10th (career/status) in Capricorn (its own sign → dignity = own_sign, strong). 10th is a kendra. → Strong, self-made career through sustained discipline; authority earned slowly but durably.",
      "note": "Same planet+house in Aries (debilitated) flips the reading: career ambition undermined by impatience or restriction. The dignity dial does the work — this is why it must be data-driven, not canned."
    }
  },
  "_next_layers": {
    "nakshatras": "All 27: lord (already in grahas.nakshatras_ruled), deity, symbol, gana, pada/navamsha mapping, shakti. Needed for Moon-sign nuance, Dasha start, and muhurta.",
    "dasha_phala": "Result rules for Mahadasha/Antardasha of each planet by house lordship and placement.",
    "yogas": "Raja yogas, Dhana yogas, Pancha Mahapurusha (Ruchaka/Bhadra/Hamsa/Malavya/Shasha), Gajakesari, Neecha Bhanga, Kemadruma, etc.",
    "divisional_charts": "D9 Navamsha (marriage/dharma), D10 Dashamsha (career), and varga strength.",
    "modifiers": "Combustion (astangata), retrograde (vakri), planetary war (graha yuddha), Sun/Moon proximity, bright/dark Moon."
  }
