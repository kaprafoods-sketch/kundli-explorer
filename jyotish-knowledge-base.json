  "dignity_rules": {
    "description": "Resolve a planet's dignity in a sign by checking, in priority order. Use this to label strength in interpretations.",
    "order": [
      "exalted",
      "moolatrikona",
      "own_sign",
      "great_friend",
      "friend",
      "neutral",
      "enemy",
      "great_enemy",
      "debilitated"
    ],
    "exalted": {
      "label": "Exalted (Uccha)",
      "strength": "very strong",
      "meaning": "Planet expresses its highest, most refined significations."
    },
    "debilitated": {
      "label": "Debilitated (Neecha)",
      "strength": "very weak",
      "meaning": "Significations are strained or distorted unless cancelled (Neecha Bhanga)."
    },
    "moolatrikona": {
      "label": "Mooltrikona",
      "strength": "strong",
      "meaning": "Near-peak strength; planet acts with full, comfortable authority."
    },
    "own_sign": {
      "label": "Own Sign (Swakshetra)",
      "strength": "strong",
      "meaning": "Planet is at home, stable and self-assured."
    },
    "friend_enemy": {
      "label": "Friendship by sign lord",
      "strength": "varies",
      "meaning": "Compute from the dispositor (the sign's ruler) using the natural relationships table. Strong in a friend's sign, weak in an enemy's."
    },
    "neecha_bhanga_note": "Debilitation can be cancelled (Neecha Bhanga Raja Yoga) under specific conditions, e.g., the dispositor is in a kendra from Lagna/Moon, or the debilitation lord is exalted. Engine should flag the possibility, not auto-resolve it.",
    "compute_hint": "function dignity(planet, sign): if sign == exaltation.sign -> exalted; if sign in mooltrikona -> moolatrikona; if sign in own_signs -> own_sign; if sign == debilitation.sign -> debilitated; else classify by relationships[planet] vs rashis[sign].ruler."
  },
  "aspect_rules": {
    "description": "Graha drishti (planetary aspects), counted as houses forward from the planet's own position. All grahas aspect the 7th fully. Special aspects add to that.",
